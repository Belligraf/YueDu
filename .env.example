# === ЛОКАЛЬНАЯ РАЗРАБОТКА (SQLite) ===
# DATABASE_URL оставь пустым или закомментируй

# Путь к файлу SQLite (можно изменить)
SQLITE_DB_PATH=

# Включи логи SQL (для отладки)
# SQLALCHEMY_ECHO=true


# === ПРОДАКШЕН / PostgreSQL ===
# DATABASE_URL=postgresql://user:password@localhost:5432/yuedu

# Или через Railway / Docker / Render:
# DATABASE_URL=postgresql://...